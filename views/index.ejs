<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>KBO 나만의 야구 네비게이터</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container py-5" style="max-width: 800px;">
    
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white rounded shadow-sm">
      <div>
        <span> 현재 접속자: <strong class="text-dark"><%= user && user.username ? user.username : '게스트' %></strong> 님 반갑습니다!</span>
      </div>
      <div>
        <a href="/logout" class="btn btn-outline-danger btn-sm">로그아웃</a>
      </div>
    </div>

    <h1 class="text-center mb-4">KBO 나만의 야구 네비게이터</h1>
    
    <div class="card mb-5 shadow-sm">
      <div class="card-body">
        <h5 class="card-title mb-3">관심 구단 등록하기</h5>
        <form action="/?_method=POST" method="POST">
          <div class="mb-3">
            <label class="form-label">KBO 구단 선택</label>
            <select name="teamName" class="form-select" required>
              <option value="" disabled selected>구단을 선택하세요</option>
              <option value="KIA 타이거즈">KIA 타이거즈</option>
              <option value="삼성 라이온즈">삼성 라이온즈</option>
              <option value="LG 트윈스">LG 트윈스</option>
              <option value="두산 베어스">두산 베어스</option>
              <option value="KT 위즈">KT 위즈</option>
              <option value="SSG 랜더스">SSG 랜더스</option>
              <option value="롯데 자이언츠">롯데 자이언츠</option>
              <option value="한화 이글스">한화 이글스</option>
              <option value="NC 다이노스">NC 다이노스</option>
              <option value="키움 히어로즈">키움 히어로즈</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary w-100">등록하기</button>
        </form>
      </div>
    </div>

    <h3 class="mb-3">나의 관심 구단 & 실시간 네이버 뉴스</h3>
    
    <% if (teams.length === 0) { %>
      <p class="text-muted text-center py-4">등록된 구단이 없습니다. 위에서 구단을 선택해 등록해 보세요!</p>
    <% } %>

    <% teams.forEach(function(team) { %>
      <div class="card mb-4 border-left border-primary shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center bg-white">
          <strong class="fs-5 text-primary"> <%= team.teamName %></strong>
          <form action="/<%= team._id %>?_method=DELETE" method="POST" onsubmit="return confirm('정말 삭제하시겠습니까?');" class="m-0">
            <button type="submit" class="btn btn-danger btn-sm">삭제</button>
          </form>
        </div>
        <div class="card-body">
          <h6 class="text-secondary mb-2"> 관련 실시간 네이버 뉴스</h6>
          <ul class="list-group list-group-flush">
            <% if (team.news && team.news.length > 0) { %>
              <% team.news.forEach(function(item) { %>
                <li class="list-group-item bg-transparent px-0">
                  <a href="<%= item.link %>" target="_blank" class="text-decoration-none text-dark fw-semibold">
                     <%- item.title %>
                  </a>
                </li>
              <% }); %>
            <% } else { %>
              <li class="list-group-item bg-transparent px-0 text-muted small">뉴스를 불러올 수 없거나 키워드가 정확하지 않습니다.</li>
            <% } %>
          </ul>
        </div>
      </div>
    <% }); %>
  </div>
</body>
</html>